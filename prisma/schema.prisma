generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres.qblyifmiyqzkfudlkrci:job-application-tracker-db@aws-0-us-west-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
}

model JobApplication {
  id          String   @id @default(uuid())
  company     String
  position    String
  status      String   @default("Applied") // Applied, Interviewing, Rejected, Offer
  url         String?  // El signo de interrogación significa que es opcional
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}