generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  Applied
  Interview
  Offer
  Rejected
}

model JobApplication {
  id          String            @id @default(uuid())
  company     String
  position    String
  status      ApplicationStatus @default(Applied)
  url         String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}